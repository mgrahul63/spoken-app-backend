  "story": {
    "title": "The Mystery at the Market Gate",
    "body": "In a busy local market, a customer named Rafi arrived every morning to set up his food stall. He would place a clean plate of rice and curry and deliver meals to various workers nearby. His actual earnings were small, but the comfort he received from his work amazed even him. One day, something strange occurred. A thief had stolen a bag of money from the gate of the market. The manager, who was in charge of the market, tried to contact the police but could not locate them quickly. The opposite side of the gate showed signs of a break-in. Rafi decided to help. He managed to include several witnesses and gave the officer a set of important clues. Though he was just a simple food seller, his sharp brain amazed the officer. The thief was caught before he could steal again. As a reward, the market board gave Rafi a letter of appreciation. He framed it and hung it beside his stall — a reminder that honest people who earn their living with dignity deserve recognition. The mystery was solved, and the market returned to its comfortable rhythm.",
    "comprehension": [
      {
        "q": "What did Rafi sell at the market?",
        "opts": ["fruits", "rice and curry meals", "clothes", "books"],
        "ans": 1
      },
      {
        "q": "What occurred at the gate?",
        "opts": ["a fire", "a theft", "an accident", "a concert"],
        "ans": 1
      },
      {
        "q": "How did Rafi help?",
        "opts": [
          "he ran away",
          "he gave clues and included witnesses",
          "he called the thief",
          "he hid the money"
        ],
        "ans": 1
      },
      {
        "q": "What did Rafi receive as a reward?",
        "opts": ["money", "a letter of appreciation", "a medal", "a new stall"],
        "ans": 1
      }
    ],
