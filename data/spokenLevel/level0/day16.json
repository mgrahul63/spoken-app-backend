  "story": {
    "title": "The Hidden Wealth of the Ancient Academy",
    "body": "In a small county, there existed an ancient academy that was over a century old. The board of the academy had a secret — a hidden room full of original manuscripts worth many pounds. One evening, a gentleman named Karim, who was a published writer, received a clue in the mail. It said: 'Maybe the wealth you seek is where music meets history.' Karim followed the process carefully. He checked every word in the dictionary, studied the board's old records, and attended a concert held at the local theater. During the concert, an officer approached him and whispered, 'There is a hidden door behind the flat wall near the stage.' Karim found it. Behind the door was a shelf of original books, ready to be published again. The academy decided to share this wealth of knowledge with the world. The story of the hidden room became famous across the county and beyond.",
    "comprehension": [
      {
        "q": "How old was the academy?",
        "opts": ["fifty years", "over a century", "ten years", "two centuries"],
        "ans": 1
      },
      {
        "q": "What did Karim receive?",
        "opts": ["money", "a clue", "a book", "a key"],
        "ans": 1
      },
      {
        "q": "Where was the hidden door?",
        "opts": [
          "in the garden",
          "behind the flat wall",
          "under the floor",
          "in the library"
        ],
        "ans": 1
      },
      {
        "q": "What was inside the hidden room?",
        "opts": ["gold coins", "original books", "old paintings", "food"],
        "ans": 1
      }
